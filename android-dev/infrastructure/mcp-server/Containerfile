FROM node:22-bookworm-slim

# Only need adb (platform-tools) — emulators run in separate containers
# Download platform-tools directly (no sdkmanager/JDK needed)
RUN apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
      ca-certificates \
      wget \
      unzip \
    && cd /tmp \
    && wget -q https://dl.google.com/android/repository/platform-tools-latest-linux.zip -O platform-tools.zip \
    && unzip -q platform-tools.zip -d /opt/android-sdk \
    && rm platform-tools.zip \
    && apt-get purge -y wget unzip \
    && apt-get autoremove -y \
    && rm -rf /var/lib/apt/lists/*

ENV PATH="${PATH}:/opt/android-sdk/platform-tools"

WORKDIR /app

COPY package.json ./
RUN npm install --omit=dev

COPY . .

EXPOSE 8000

CMD ["node", "server.mjs"]
