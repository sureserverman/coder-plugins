FROM debian:bookworm-slim@sha256:f9c6a2fd2ddbc23e336b6257a5245e31f996953ef06cd13a59fa0a1df2d5c252

# Emulator runtime dependencies (JDK needed for avdmanager/sdkmanager)
RUN apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
      openjdk-17-jdk-headless \
      wget \
      unzip \
      libglu1-mesa \
      libpulse0 \
      libnss3 \
      libx11-6 \
      libx11-xcb1 \
      libxcomposite1 \
      libxcursor1 \
      libxdamage1 \
      libxi6 \
      libxtst6 \
      libxrandr2 \
      libasound2 \
      procps \
      bash \
    && rm -rf /var/lib/apt/lists/*

ENV ANDROID_SDK_ROOT=/opt/android-sdk \
    ANDROID_HOME=/opt/android-sdk \
    ANDROID_AVD_HOME=/avd
ENV PATH="${PATH}:${ANDROID_SDK_ROOT}/cmdline-tools/latest/bin:${ANDROID_SDK_ROOT}/platform-tools:${ANDROID_SDK_ROOT}/emulator"

# Pinned commandline-tools build (revision 11391160) plus a SHA-256 verification
# step so a CDN compromise can't substitute bytes silently. Bump CMDLINE_REV and
# CMDLINE_SHA256 together as part of routine dependency hygiene.
ARG CMDLINE_REV=11391160
ARG CMDLINE_URL=https://dl.google.com/android/repository/commandlinetools-linux-${CMDLINE_REV}_latest.zip
ARG CMDLINE_SHA256=0a35ce4da4f8562fa21b9637e27624b04916827a1daff1e40035f216598cd2c3

# Install Android SDK at build time (eliminates cross-container coordination)
RUN mkdir -p ${ANDROID_SDK_ROOT}/cmdline-tools && \
    cd /tmp && \
    wget -q "${CMDLINE_URL}" -O cmdline-tools.zip && \
    echo "${CMDLINE_SHA256}  cmdline-tools.zip" | sha256sum -c - && \
    unzip -q cmdline-tools.zip -d ${ANDROID_SDK_ROOT}/cmdline-tools && \
    mv ${ANDROID_SDK_ROOT}/cmdline-tools/cmdline-tools ${ANDROID_SDK_ROOT}/cmdline-tools/latest && \
    rm cmdline-tools.zip && \
    yes | sdkmanager --licenses >/dev/null 2>&1 && \
    sdkmanager "platform-tools" "emulator" "platforms;android-35" \
      "system-images;android-35;google_apis;x86_64" && \
    rm -rf /tmp/*

COPY entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

ENTRYPOINT ["/entrypoint.sh"]
