FROM node:22-bookworm-slim

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci --omit=dev && npm cache clean --force

COPY . .

RUN chown -R node:node /app

USER node

EXPOSE 8008

# MOCK_MODE=1 must be set in the runtime env (compose.yaml) — the server
# refuses to start otherwise. Public test fixtures are not real auth.
CMD ["node", "server.mjs"]
