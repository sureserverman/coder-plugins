{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "shell",
        "hooks": [
          {
            "type": "command",
            "command": "./scripts/audit-tool-call.sh"
          }
        ]
      }
    ],
    "AgentTurnComplete": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./scripts/notify.sh"
          }
        ]
      }
    ]
  }
}
